APP_NAME=Messaging Portfolio API
APP_ENV=local
APP_PORT=8000

DB_HOST=db
DB_PORT=5432
DB_NAME=portfolio
DB_USER=portfolio
DB_PASSWORD=portfolio

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SENTINEL_ENABLED=false
REDIS_SENTINEL_MASTER=mymaster
REDIS_SENTINEL_NODES=redis-sentinel-0.redis-headless:26379,redis-sentinel-1.redis-headless:26379,redis-sentinel-2.redis-headless:26379

STARTUP_RETRIES=30
STARTUP_RETRY_DELAY=2
NOTIFICATION_QUEUE=message_notifications
INGRESS_QUEUE=message_ingress
INGRESS_PARTITIONS=8
INGRESS_DLQ=message_ingress_dlq
INGRESS_MAX_RETRIES=3
INGRESS_RETRY_BASE_DELAY_SECONDS=2
ROOM_SEQ_KEY_PREFIX=room_seq
DLQ_REPLAY_ENABLED=true
DLQ_REPLAY_INTERVAL_SECONDS=0.2
DLQ_REPLAY_BATCH_SIZE=5
OBSERVER_PORT=8081
WORKER_METRICS_PORT=9101
