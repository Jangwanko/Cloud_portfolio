APP_NAME=Messaging Portfolio API
APP_ENV=local
APP_PORT=8000

DB_HOST=db
DB_PORT=5432
DB_NAME=portfolio
DB_USER=portfolio
DB_PASSWORD=portfolio

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SENTINEL_ENABLED=false
REDIS_SENTINEL_MASTER=mymaster
REDIS_SENTINEL_NODES=redis-sentinel-0.redis-headless:26379,redis-sentinel-1.redis-headless:26379,redis-sentinel-2.redis-headless:26379

STARTUP_RETRIES=30
STARTUP_RETRY_DELAY=2
NOTIFICATION_QUEUE=message_notifications
OBSERVER_PORT=8081
