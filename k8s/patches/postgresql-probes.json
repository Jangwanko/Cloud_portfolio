{
  "spec": {
    "template": {
      "spec": {
        "containers": [
          {
            "name": "postgresql",
            "livenessProbe": {
              "exec": {
                "command": [
                  "/bin/bash",
                  "-ec",
                  "pg_isready -h 127.0.0.1 -p 5432 -U portfolio -d portfolio"
                ]
              },
              "initialDelaySeconds": 20,
              "periodSeconds": 10,
              "timeoutSeconds": 5,
              "failureThreshold": 6
            },
            "readinessProbe": {
              "exec": {
                "command": [
                  "/bin/bash",
                  "-ec",
                  "pg_isready -h 127.0.0.1 -p 5432 -U portfolio -d portfolio"
                ]
              },
              "initialDelaySeconds": 10,
              "periodSeconds": 10,
              "timeoutSeconds": 5,
              "failureThreshold": 6
            }
          }
        ]
      }
    }
  }
}
